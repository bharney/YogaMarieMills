# Docker Environment Configuration Example
# Copy this file to .env.docker and fill in your actual values

# Node environment
NODE_ENV=production

# MSSQL Database Configuration
DB_SERVER=your-server.database.windows.net
DB_DATABASE=yogamariemills
DB_USER=dbadmin
DB_PASSWORD=YourDatabasePassword123!
DB_PORT=1433

# Seed Admin Credentials (for initial database population)
SEED_ADMIN_EMAIL=admin@yogamariemills.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_FIRST_NAME=Marie
SEED_ADMIN_LAST_NAME=Mills
