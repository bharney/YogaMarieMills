# Application secrets
JWT_SECRET=replace_with_secure_jwt_secret
DATABASE_URL=replace_with_database_connection_string

# Optional Key Vault bootstrap (if provided, startup loads secrets from Key Vault)
AZURE_KEY_VAULT_NAME=your-key-vault-name
# AZURE_KEY_VAULT_URL=https://your-key-vault-name.vault.azure.net
KEYVAULT_DATABASE_URL_SECRET=DATABASE-URL
KEYVAULT_JWT_SECRET_NAME=JWT-SECRET

# Seed admin user (used by tools/dbResetSeedAll.js)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
